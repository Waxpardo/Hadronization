universe   = vanilla

# Wrapper that sets up env and runs Pythia
executable = /data/alice/ipardoza/Hadronization/runCondorJob.sh
initialdir = /data/alice/ipardoza/Hadronization

# Inherit basic env (HOME, etc.). setupEnv.sh is still sourced inside.
getenv = True

request_cpus   = 1
request_memory = 4GB
request_disk   = 10GB

# Required by Stoomboot
+JobCategory = "short"
+UseOS       = "el9"

# Logging
log    = logs/job_$(Cluster)_$(JOBID)_$(CHANNEL)_$(TUNE).log
output = logs/job_$(Cluster)_$(JOBID)_$(CHANNEL)_$(TUNE).out
error  = logs/job_$(Cluster)_$(JOBID)_$(CHANNEL)_$(TUNE).err

# Shared filesystem (/data/alice), no Condor file transfer
should_transfer_files = NO

# 1,000,000 events/job × 10 jobs per (CHANNEL, TUNE) combination = 10,000,000 events
NEVT_PER_JOB = 1000000

# Arguments to runCondorJob.sh:
#   JOBID   = $(JOBID)
#   CHANNEL = $(CHANNEL)
#   TUNE    = $(TUNE)
#   NEVT    = $(NEVT_PER_JOB)
arguments = $(JOBID) $(CHANNEL) $(TUNE) $(NEVT_PER_JOB)

# bbbar MONASH
CHANNEL = bbbar
TUNE    = MONASH
queue JOBID from (
0
1
2
